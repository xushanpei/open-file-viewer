{
  "name": "@open-file-viewer/core",
  "version": "0.1.15",
  "description": "Framework-agnostic browser file preview core.",
  "license": "MIT",
  "type": "module",
  "homepage": "https://open-file-viewer-workspace.void.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xushanpei/open-file-viewer.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/xushanpei/open-file-viewer/issues"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./style.css": {
      "default": "./dist/style.css"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --sourcemap --clean && node ../../scripts/copy-file.mjs src/style.css dist/style.css",
    "typecheck": "tsc --noEmit"
  },
  "peerDependenciesMeta": {
    "@mlightcad/libredwg-web": {
      "optional": true
    },
    "pdfjs-dist": {
      "optional": true
    }
  },
  "peerDependencies": {
    "@mlightcad/libredwg-web": ">=0.7.4",
    "pdfjs-dist": ">=4"
  },
  "devDependencies": {
    "@mlightcad/libredwg-web": "0.7.4",
    "@types/leaflet": "^1.9.21",
    "@types/marked": "^6.0.0",
    "@types/pako": "^2.0.4",
    "@types/prismjs": "^1.26.6",
    "@types/three": "^0.184.1",
    "@types/topojson-client": "^3.1.5",
    "pdfjs-dist": "^4.10.38"
  },
  "dependencies": {
    "@aiden0z/pptx-renderer": "^1.0.3",
    "@kenjiuno/msgreader": "^1.28.0",
    "@mapbox/togeojson": "^0.16.2",
    "ag-psd": "^30.2.0",
    "docx-preview": "^0.3.7",
    "dompurify": "^3.4.10",
    "heic2any": "^0.0.4",
    "hls.js": "^1.6.16",
    "hyparquet": "^1.26.1",
    "jszip": "^3.10.1",
    "leaflet": "^1.9.4",
    "mammoth": "^1.12.0",
    "marked": "^18.0.4",
    "pako": "^2.1.0",
    "postal-mime": "^2.7.4",
    "prismjs": "^1.30.0",
    "seek-bzip": "^2.0.0",
    "shpjs": "^6.2.0",
    "three": "^0.184.0",
    "topojson-client": "^3.1.0",
    "utif": "^3.1.0",
    "xlsx": "^0.18.5",
    "xz-decompress": "^0.2.3"
  }
}
